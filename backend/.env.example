# BlockVerify backend secrets — copy to `.env` and fill in.
# `.env` is gitignored; never commit real keys.

# Google Gemini API key (powers the in-app AI assistant /api/chat)
GEMINI_API_KEY=your_gemini_api_key_here

# Bitcoin Testnet WIF private key for the OP_RETURN anchoring wallet.
# Testnet only — no real-money value. If unset, a throwaway demo key is used.
BTC_WIF=your_bitcoin_testnet_wif_here

# Port for the Flask server (Render sets this automatically).
# PORT=5000
